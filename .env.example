# KudaGo Public API v1.4
KUDAGO_BASE_URL=https://kudago.com/public-api/v1.4/
KUDAGO_LANG=ru

# Nominatim-compatible API. For production it is better to use your own/self-hosted endpoint or proxy.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/
NOMINATIM_USER_AGENT=internet-search-bot-kudago-mcp/0.1.0 (replace-with-real-contact-email-or-url)
NOMINATIM_REFERER=
NOMINATIM_EMAIL=
NOMINATIM_MIN_INTERVAL_SECONDS=1.0
NOMINATIM_COUNTRYCODES=ru

DEFAULT_RADIUS=50000
TRUST_ENV=true
LOG_DIR=logging
DEBUG=0

# Transport selector. stdio is default for backward compatibility.
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8010
MCP_PATH=/mcp/
