# Настройки приложения
APP_NAME=KudaGo FastAPI Service
DEBUG=1

# Подключение к PostgreSQL
POSTGRES_USER=kudago
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kudago_service
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://kudago:change-me@127.0.0.1:5433/kudago_service

# Подключение к Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Интеграция с KudaGo
KUDAGO_BASE_URL=https://kudago.com/public-api/v1.4/
KUDAGO_LANG=ru
KUDAGO_USER_AGENT=kudago-fastapi-service/0.1.0

# Интеграция с Nominatim
NOMINATIM_USER_AGENT=kudago-fastapi-service/0.1.0
NOMINATIM_MIN_INTERVAL_SECONDS=1.0
NOMINATIM_COUNTRYCODES=ru

# Параметры географического поиска
DEFAULT_RADIUS=50000
