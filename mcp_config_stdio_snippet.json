{
    "name": "kudago_nominatim",
    "alias": "kudago",
    "connect_type": "executable",
    "executable": "python",
    "args": ["/absolute/path/to/kudago_nominatim_mcp_server.py"],
    "env": {
        "DEBUG": "1",
        "KUDAGO_BASE_URL": "https://kudago.com/public-api/v1.4/",
        "KUDAGO_LANG": "ru",
        "NOMINATIM_BASE_URL": "https://nominatim.openstreetmap.org/",
        "NOMINATIM_USER_AGENT": "kudago-nominatim-mcp/0.1.0 (replace-with-real-contact-email-or-url)",
        "NOMINATIM_EMAIL": "",
        "NOMINATIM_MIN_INTERVAL_SECONDS": "1.0",
        "NOMINATIM_COUNTRYCODES": "ru",
        "DEFAULT_RADIUS": "50000",
        "KUDAGO_LOCATIONS_CACHE_TTL": "900",
        "TRUST_ENV": "true",
        "LOG_DIR": "logging"
    },
    "enabled": true
}
